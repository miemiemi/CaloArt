.env
.env.*
!.env.example

.project-root
.vscode/

__pycache__/
*.py[cod]

# Local run artifacts
logs/*
!logs/.gitkeep
!logs/slurm/
!logs/archive/
logs/slurm/*
!logs/slurm/.gitkeep
logs/archive/*
!logs/archive/.gitkeep
outputs/
experiments/
generations/
wandb/

# Job and training logs
*.log
*.out
*.err

# Private one-off launchers can live here without polluting git status.
scripts/slurm/local/*
!scripts/slurm/local/.gitkeep

# Common generated model/data artifacts
*.h5
*.pt
*.pth
*.ckpt

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
